# =============================================================================
# x402 Autopilot — Environment Variables
# =============================================================================
# Copy to .env and fill in your values:  cp .env.example .env

# --- Stellar Wallet ---
# Main agent wallet keypair (fund via Friendbot: https://friendbot.stellar.org?addr=PUBLIC_KEY)
STELLAR_PRIVATE_KEY=S...your_secret_key
STELLAR_PUBLIC_KEY=G...your_public_key
STELLAR_NETWORK=stellar:testnet

# --- Soroban Contracts ---
#
# WALLET-POLICY: You MUST deploy your own. The wallet-policy contract requires
# owner auth for record_spend, record_denied, update_policy, and set_allowlist.
# Only the deployer's key can call these functions. Read functions (check_policy,
# get_today_spending, get_lifetime_stats) are public.
#
#   Deploy your own:  npm run deploy:wallet-policy
#
# TRUST-REGISTRY: Shared on testnet. Anyone can register services and read.
# Service owners must sign their own heartbeat / deregister calls. You can use
# the pre-deployed shared one or deploy your own.
#
#   Pre-deployed:     CBMZL7YHPV2UFDK7S7OQOE46TAPULOMKRK7W2OZONP3ZUXUA3S6RMRAJ
#   Deploy your own:  npm run deploy:trust-registry
#
WALLET_POLICY_CONTRACT_ID=C...deploy_your_own
TRUST_REGISTRY_CONTRACT_ID=CBMZL7YHPV2UFDK7S7OQOE46TAPULOMKRK7W2OZONP3ZUXUA3S6RMRAJ

# --- Soroban RPC ---
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# --- USDC (Stellar testnet) ---
# Issuer: GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5
# Faucet: https://faucet.circle.com (select Stellar)
USDC_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5
USDC_SAC_CONTRACT_ID=CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA

# --- x402 Facilitator (OpenZeppelin) ---
# Generate key at: https://channels.openzeppelin.com/testnet/gen
# The data-sources servers fall back to https://x402.org/facilitator
# (Coinbase) if OZ_FACILITATOR_URL is unset, but the core engine in src/
# always uses the OZ URL above.
OZ_FACILITATOR_URL=https://channels.openzeppelin.com/x402/testnet
OZ_API_KEY=your_oz_api_key

# --- Data Source Wallets (seller wallets for demo APIs) ---
# Leave these empty — `npm run dev` auto-generates, funds, and writes each
# service wallet on its first start (Friendbot + USDC trustline + $0.10 from
# the main wallet). Each service gets its own distinct wallet so payments
# show up on the dashboard as real transfers between two different nodes.
#
# Do NOT set any of these to STELLAR_PUBLIC_KEY. Self-transfers are filtered
# out of the activity feed and would make the demo look broken.
#
# Env var names are retained from the original weather/stellar-data services
# for backwards compatibility with setup-service-wallets.ts and package.json
# scripts. The services they point at now are the agent network:
#   WEATHER_API_*     -> Crypto Price Oracle (:4001)
#   NEWS_API_*        -> News Intelligence Agent (:4002)
#   STELLAR_DATA_API_*-> Market Intelligence Agent (:4003)
#
# To re-run the auto-setup manually: npm run setup:service-wallets
WEATHER_API_WALLET=
WEATHER_API_SECRET=
NEWS_API_WALLET=
NEWS_API_SECRET=
STELLAR_DATA_API_WALLET=
STELLAR_DATA_API_SECRET=

# --- Policy Defaults (stroops: 1 USDC = 10_000_000) ---
DEFAULT_DAILY_LIMIT=5000000
DEFAULT_PER_TX_LIMIT=1000000
DEFAULT_RATE_LIMIT=60

# --- MPP (Machine Payments Protocol) ---
# Secret key for HMAC challenge binding (required for MPP charge server)
# Generate with: openssl rand -hex 32
MPP_SECRET_KEY=your_mpp_secret_key_change_me

# --- Analyst Agent ---
# The analyst has its OWN wallet (separate from the main agent).
# It earns money by selling analyses and spends money to buy raw data.
# Generate keypair: stellar keys generate analyst --network testnet
# Fund via Friendbot, add USDC trustline, send USDC from main wallet.
ANALYST_PRIVATE_KEY=S...analyst_secret_key
ANALYST_PUBLIC_KEY=G...analyst_public_key
# LLM model the analyst uses when spawning `claude -p` (OAuth subscription).
# Sonnet is the default — it responds in ~5-10s vs ~20-30s for Opus, which
# matters because Claude Desktop's MCP tool cap is hardcoded at 60s.
# Options: claude-sonnet-4-6, claude-opus-4-6, claude-haiku-4-5-20251001
ANALYST_CLAUDE_MODEL=claude-sonnet-4-6

# Per-agent Claude model overrides for the other two agent endpoints.
# Same model options as ANALYST_CLAUDE_MODEL. Each agent defaults to
# claude-sonnet-4-6 if unset — change these to run a mixed network.
NEWS_CLAUDE_MODEL=claude-sonnet-4-6
MARKET_CLAUDE_MODEL=claude-sonnet-4-6
# Optional: Anthropic API key — ONLY used as a fallback if `claude -p` fails.
# If both are unset, /analyze still works but returns the raw weather + news
# data without an LLM-generated summary.
# ANTHROPIC_API_KEY=sk-ant-...

# --- Data Source Ports ---
PORT_WEATHER_API=4001
PORT_NEWS_API=4002
PORT_STELLAR_DATA_API=4003
PORT_ANALYST_API=4004

# --- Local Dev ---
# Set to true to allow http:// and localhost URLs (dev only)
ALLOW_HTTP=true

# --- Dashboard WebSocket ---
WS_PORT=8080
# Bind address for the ws-server. Default is 127.0.0.1 (loopback only).
# The relay handler accepts arbitrary `_relay` payloads from any connected
# client and rebroadcasts them, so binding to 0.0.0.0 would let any host
# on the network inject fake spend:ok events into every dashboard. Even
# with WS_BIND_ADDR=0.0.0.0 the relay handler still requires a loopback
# peer (defence in depth), but only override the default if you genuinely
# need the dashboard reachable from another host on a trusted network.
WS_BIND_ADDR=127.0.0.1

# --- MCP Server ---
MCP_SERVER_PORT=3000
